---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionLabel from "../components/SectionLabel.astro";
import ConsultationForm from "../components/ConsultationForm.astro";
import { site } from "../data/site";
---

<BaseLayout
  title="Contatti — Mood Beauty Lab | Pavia"
  description={`Mood Beauty Lab — ${site.address.street}, ${site.address.city}. Contattaci per prenotare la tua consulenza personalizzata. ${site.phone}`}
>
  <PageHero
    label="See You at Mood"
    title="Dove siamo."
    titleAccent=""
    subtitle="Il tuo spazio dedicato all'estetica avanzata a Pavia. Vieni a trovarci o scrivici per fissare la tua consulenza."
  />

  {/* INFO + MAP */}
  <section class="section-padding bg-warm-white">
    <div class="max-w-[1280px] mx-auto px-8 md:px-12 lg:px-14 xl:px-10">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16">
        {/* Contact info */}
        <div data-reveal>
          <SectionLabel text="Contatti" />
          <h2 class="font-display text-3xl md:text-4xl text-navy leading-tight mb-10">
            Mood<span class="text-magenta">.</span> Beauty Lab
          </h2>

          <div class="space-y-8">
            {/* Address */}
            <div class="flex items-start gap-5">
              <div class="w-12 h-12 rounded-xl bg-blush flex items-center justify-center shrink-0">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-magenta">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-navy mb-1 uppercase tracking-wider">Indirizzo</h3>
                <a href={site.mapsUrl} target="_blank" rel="noopener" class="text-navy/70 hover:text-magenta transition-colors">
                  {site.address.street}<br />
                  {site.address.cap} {site.address.city}, {site.address.region}
                </a>
              </div>
            </div>

            {/* Phone */}
            <div class="flex items-start gap-5">
              <div class="w-12 h-12 rounded-xl bg-blush flex items-center justify-center shrink-0">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-magenta">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-navy mb-1 uppercase tracking-wider">Telefono</h3>
                <a href={site.phoneHref} class="text-navy/70 hover:text-magenta transition-colors text-lg">
                  {site.phone}
                </a>
              </div>
            </div>

            {/* Email */}
            <div class="flex items-start gap-5">
              <div class="w-12 h-12 rounded-xl bg-blush flex items-center justify-center shrink-0">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-magenta">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                  <polyline points="22,6 12,13 2,6" />
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-navy mb-1 uppercase tracking-wider">Email</h3>
                <a href={`mailto:${site.email}`} class="text-navy/70 hover:text-magenta transition-colors break-all">
                  {site.email}
                </a>
              </div>
            </div>

            {/* Instagram */}
            {
              site.social.instagram && (
                <div class="flex items-start gap-5">
                  <div class="w-12 h-12 rounded-xl bg-blush flex items-center justify-center shrink-0">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-magenta">
                      <rect x="2" y="2" width="20" height="20" rx="5" />
                      <circle cx="12" cy="12" r="4" />
                      <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-sm font-semibold text-navy mb-1 uppercase tracking-wider">Instagram</h3>
                    <a href={site.social.instagram} target="_blank" rel="noopener" class="text-navy/70 hover:text-magenta transition-colors">
                      @moodbeautylab
                    </a>
                  </div>
                </div>
              )
            }
          </div>

          {/* Hours note */}
          <div class="mt-10 p-6 rounded-2xl bg-blush">
            <h3 class="text-sm font-semibold text-navy mb-2 uppercase tracking-wider">Orari</h3>
            <p class="text-sm text-navy/60 leading-relaxed">
              Su appuntamento. Contattaci per concordare il tuo appuntamento
              nei giorni e orari più comodi per te.
            </p>
          </div>
        </div>

        {/* Map */}
        <div data-reveal data-reveal-delay="2">
          <div class="relative rounded-3xl overflow-hidden h-full min-h-[450px] lg:min-h-full border border-navy/10 shadow-lg bg-blush">
            <div id="map-consent" class="absolute inset-0 z-10 flex items-center justify-center p-8 text-center">
              <div class="max-w-sm">
                <p class="text-label text-magenta mb-4">Mappa</p>
                <h3 class="font-display text-3xl text-navy mb-4">Via San Paolo 5g, Pavia</h3>
                <p class="text-sm text-navy/60 leading-relaxed mb-6">
                  Per proteggere la tua privacy, la mappa Google viene caricata solo quando scegli di visualizzarla.
                  Prima del click non viene caricato l'iframe di Google Maps. Dettagli nella
                  <a href="/cookie-policy" class="text-magenta font-semibold underline underline-offset-4">Cookie Policy</a>.
                </p>
                <div class="flex flex-col sm:flex-row justify-center gap-3">
                  <button type="button" id="load-map" class="btn-primary !bg-magenta !border-magenta">
                    Carica mappa
                  </button>
                  <a href={site.mapsUrl} target="_blank" rel="noopener" class="btn-outline">
                    Apri Maps
                  </a>
                </div>
              </div>
            </div>
            <iframe
              data-src={`https://maps.google.com/maps?q=${encodeURIComponent("Via San Paolo 5g, Pavia, Italia")}&t=&z=15&ie=UTF8&iwloc=&output=embed`}
              width="100%"
              height="100%"
              style="border:0; min-height: 450px;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Mappa Mood Beauty Lab — Via San Paolo 5g, Pavia"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* FORM */}
  <section class="pb-16 lg:pb-24 bg-warm-white">
    <div class="max-w-[1280px] mx-auto px-8 md:px-12 lg:px-14 xl:px-10">
      <ConsultationForm />
    </div>
  </section>

<script>
  const loadMapButton = document.getElementById("load-map");
  const mapConsent = document.getElementById("map-consent");
  const mapFrame = document.querySelector<HTMLIFrameElement>("iframe[data-src]");

  loadMapButton?.addEventListener("click", () => {
    if (mapFrame?.dataset.src && !mapFrame.src) {
      mapFrame.src = mapFrame.dataset.src;
    }
    mapConsent?.classList.add("opacity-0", "pointer-events-none");
  });
</script>
</BaseLayout>
