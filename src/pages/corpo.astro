---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionLabel from "../components/SectionLabel.astro";
import TreatmentCard from "../components/TreatmentCard.astro";
import ImagePlaceholder from "../components/ImagePlaceholder.astro";
import ConsultationForm from "../components/ConsultationForm.astro";
import { corpoCategories } from "../data/treatments";
import { corpoImages } from "../data/images";
import { seoPages, serviceSchemas } from "../data/seo";
---

<BaseLayout
  title={seoPages.corpo.title}
  description={seoPages.corpo.description}
  structuredData={serviceSchemas.corpo}
>
  <PageHero
    label="Body by Mood"
    title="Sentirti bene"
    titleAccent="è il primo obiettivo."
    subtitle="Non parliamo di perfezione, ma di leggerezza, benessere, armonia e di un corpo in cui sentirsi bene, ogni giorno. Nessuna promessa impossibile. Solo percorsi studiati sulle esigenze di ogni persona."
  />

  {/* QUANTE VOLTE */}
  <section class="section-padding bg-warm-white">
    <div class="max-w-[1280px] mx-auto px-8 md:px-12 lg:px-14 xl:px-10">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-7" data-reveal>
          <SectionLabel text="Il tuo corpo" />
          <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-navy leading-[1.05] mb-8">
            Merita di essere vissuto,<br />
            <span class="italic text-magenta">non nascosto.</span>
          </h2>
          <div class="space-y-5 text-navy/60 leading-relaxed text-lg">
            <p>
              Quante volte hai smesso di indossare qualcosa che ti piaceva?
              Un vestito, un bikini o quei pantaloncini che ti piacevano tanto.
            </p>
            <p>
              Da Mood incontriamo ogni giorno donne che ci raccontano queste piccole
              insicurezze. E sappiamo quanto possano influenzare il modo in cui ci sentiamo.
            </p>
            <p>
              Il nostro lavoro non è inseguire la perfezione.
              È aiutarti a ritrovare sicurezza, leggerezza e benessere attraverso
              percorsi costruiti sulle tue esigenze e sui tuoi obiettivi.
            </p>
          </div>
        </div>
        <div class="lg:col-span-5 space-y-4" data-reveal data-reveal-delay="2">
          <ImagePlaceholder src={corpoImages.intro} ratio="aspect-[5/4] rounded-3xl" alt="Trattamenti corpo Mood" overlay="dark" class="shadow-lg" reveal />
          {[
            { t: "Cellulite", d: "Condizione fisiologica che interessa la maggior parte delle donne. Ogni corpo la vive in modo diverso." },
            { t: "Ritenzione idrica", d: "Gambe pesanti, gonfiore, stanchezza. Lavoriamo per regalare al corpo una piacevole sensazione di leggerezza." },
            { t: "Smagliature", d: "Ogni segno racconta una storia. Accompagniamo la pelle nel suo naturale processo di rinnovamento." },
          ].map((item, i) => (
            <div class="flex gap-5 items-start p-5 rounded-2xl bg-blush hover:bg-magenta/10 transition-colors duration-300">
              <span class="font-display text-2xl text-magenta/50 shrink-0">{String(i + 1).padStart(2, "0")}</span>
              <div>
                <h3 class="font-display text-lg text-navy mb-1">{item.t}</h3>
                <p class="text-sm text-navy/60 leading-relaxed">{item.d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* WHAT CAN YOU FIND */}
  <section class="section-padding bg-navy-50">
    <div class="max-w-[1280px] mx-auto px-8 md:px-12 lg:px-14 xl:px-10">
      <div class="max-w-3xl mb-14" data-reveal>
        <SectionLabel text="What can you find at Mood?" />
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-navy leading-[1.05]">
          Ogni corpo cambia.<br />
          <span class="italic text-magenta">E noi cambiamo con te.</span>
        </h2>
      </div>

      {/* Featured */}
      <div class="grid md:grid-cols-3 gap-5 mb-16">
        {[
          {
            name: "ICOONE",
            tag: "Tecnologia",
            featured: true,
            description:
              "Una tecnologia, tantissime possibilità. Microstimolazioni meccaniche per drenaggio, cellulite, tonicità e benessere dei tessuti.",
          },
          {
            name: "Lux Ritual Mood Relax",
            tag: "Rituale",
            description:
              "90 minuti total body rilassante con olio caldo e focus su viso, mani, piedi e cuoio capelluto. Comprensivo di aperitivo.",
          },
          {
            name: "Goodbye Cellulite & Smagliature",
            description:
              "Trattamento di biostimolazione per trattare in modo efficace e risolutivo smagliature, cicatrici e cellulite.",
          },
        ].map((t, i) => (
          <div class="tilt-wrap" data-reveal data-reveal-delay={String(i + 1)}>
            <div class="tilt-card group">
              <div class="rounded-2xl overflow-hidden mb-4 shadow-lg">
                <img
                  src={corpoImages.featured[i]}
                  alt={`${t.name} — trattamento corpo Mood`}
                  loading="lazy"
                  decoding="async"
                  class="w-full aspect-[4/5] object-cover group-hover:scale-105 transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]"
                />
              </div>
            </div>
            <TreatmentCard name={t.name} description={t.description} tag={t.tag} featured={t.featured} />
          </div>
        ))}
      </div>

      {/* Full list */}
      {corpoCategories.map((cat) => (
        <div class="mb-12 last:mb-0">
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2 mb-6 pb-4 border-b border-navy/10">
            <h3 class="font-display text-2xl md:text-3xl text-navy" data-reveal>{cat.label}</h3>
            {cat.subtitle && (
              <p class="text-sm text-navy/50" data-reveal>{cat.subtitle}</p>
            )}
          </div>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
            {cat.treatments.map((t) => (
              <TreatmentCard name={t.name} description={t.description} tag={t.tag} />
            ))}
          </div>
          {cat.note && (
            <p class="mt-6 text-sm text-magenta bg-magenta/10 rounded-xl px-5 py-4 border border-magenta/20">
              {cat.note}
            </p>
          )}
        </div>
      ))}
    </div>
  </section>

  {/* CTA con imagen editorial */}
  <section class="section-padding bg-warm-white">
    <div class="max-w-[1280px] mx-auto px-8 md:px-12 lg:px-14 xl:px-10">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
        <div class="lg:col-span-5" data-reveal>
          <ImagePlaceholder
            src={corpoImages.detail}
            ratio="aspect-[4/5] rounded-3xl"
            alt="Dettaglio trattamento corpo Mood"
            overlay="dark"
            reveal
            class="shadow-xl"
          />
        </div>
        <div class="lg:col-span-7" data-reveal data-reveal-delay="2">
          <SectionLabel text="And so much more..." />
          <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-navy leading-tight mb-6">
            Ogni corpo è diverso.<br />
            <span class="italic text-magenta">Il nostro lavoro è aiutarti.</span>
          </h2>
          <p class="text-lg text-navy/60 leading-relaxed mb-8">
            Costruiremo insieme il percorso più adatto alle tue esigenze e ai tuoi obiettivi.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contatti#consulenza" class="btn-primary">Prenota la tua consulenza</a>
            <a href="/contatti" class="btn-outline">Richiedi il listino completo</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* FORM */}
  <section class="pb-16 lg:pb-24 bg-warm-white">
    <div class="max-w-[1280px] mx-auto px-8 md:px-12 lg:px-14 xl:px-10">
      <ConsultationForm />
    </div>
  </section>
</BaseLayout>
