---
import { site } from "../data/site";

const message = "Ciao Mood Beauty Lab, vorrei prenotare una consulenza.";
const whatsappUrl = `${site.whatsappHref}?text=${encodeURIComponent(message)}`;
---

<a
  href={whatsappUrl}
  class="whatsapp-float group"
  data-whatsapp-float
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Scrivi a Mood Beauty Lab su WhatsApp"
>
  <span class="whatsapp-float__label">WhatsApp</span>
  <span class="whatsapp-float__icon" aria-hidden="true">
    <svg viewBox="0 0 32 32" focusable="false">
      <path
        fill="currentColor"
        d="M16.01 4.25c-6.46 0-11.72 5.17-11.72 11.53 0 2.05.55 4.04 1.58 5.79L4.19 27.7l6.34-1.62a11.92 11.92 0 0 0 5.48 1.34c6.46 0 11.72-5.17 11.72-11.53S22.47 4.25 16.01 4.25Zm0 21.13c-1.75 0-3.46-.47-4.95-1.35l-.36-.21-3.76.96 1-3.63-.24-.37a9.38 9.38 0 0 1-1.46-5c0-5.24 4.38-9.5 9.77-9.5s9.77 4.26 9.77 9.5-4.38 9.6-9.77 9.6Zm5.35-7.12c-.29-.15-1.73-.84-1.99-.94-.27-.1-.46-.15-.66.15-.2.29-.76.94-.94 1.13-.17.2-.34.22-.63.08-.29-.15-1.23-.45-2.35-1.43-.87-.76-1.45-1.7-1.62-1.99-.17-.29-.02-.45.13-.59.13-.13.29-.34.44-.51.15-.17.2-.29.29-.49.1-.2.05-.37-.02-.51-.07-.15-.66-1.56-.9-2.14-.24-.56-.48-.49-.66-.5h-.56c-.2 0-.51.07-.78.37-.27.29-1.03 1-1.03 2.43s1.06 2.82 1.21 3.02c.15.2 2.09 3.15 5.06 4.41.71.3 1.26.48 1.69.61.71.22 1.35.19 1.86.11.57-.08 1.73-.69 1.98-1.36.24-.67.24-1.24.17-1.36-.07-.12-.27-.19-.56-.34Z"
      />
    </svg>
  </span>
</a>

<style>
  .whatsapp-float {
    position: fixed;
    right: max(1.25rem, env(safe-area-inset-right));
    bottom: calc(max(1.25rem, env(safe-area-inset-bottom)) + var(--mood-whatsapp-lift, 0px));
    z-index: 35;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    min-height: 3.4rem;
    padding: 0.45rem 0.55rem 0.45rem 1rem;
    color: white;
    background: #25d366;
    border-radius: 999px;
    box-shadow: 0 14px 34px rgba(5, 15, 56, 0.22);
    text-decoration: none;
    transition:
      transform 0.35s var(--ease-mood),
      box-shadow 0.35s var(--ease-mood),
      background-color 0.35s var(--ease-mood);
  }

  .whatsapp-float::before {
    content: "";
    position: absolute;
    inset: -0.35rem;
    z-index: -1;
    border-radius: inherit;
    background: rgba(37, 211, 102, 0.18);
    opacity: 0;
    transform: scale(0.92);
    transition:
      opacity 0.35s var(--ease-mood),
      transform 0.35s var(--ease-mood);
  }

  .whatsapp-float:hover {
    transform: translateY(-3px);
    background: #1ebe5d;
    box-shadow: 0 18px 42px rgba(5, 15, 56, 0.28);
  }

  .whatsapp-float:hover::before {
    opacity: 1;
    transform: scale(1);
  }

  .whatsapp-float:focus-visible {
    outline: 2px solid var(--color-magenta);
    outline-offset: 4px;
  }

  .whatsapp-float__label {
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .whatsapp-float__icon {
    display: inline-grid;
    width: 2.5rem;
    height: 2.5rem;
    place-items: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
  }

  .whatsapp-float svg {
    width: 1.85rem;
    height: 1.85rem;
  }

  @media (max-width: 640px) {
    .whatsapp-float {
      right: max(1rem, env(safe-area-inset-right));
      bottom: calc(max(1rem, env(safe-area-inset-bottom)) + var(--mood-whatsapp-lift, 0px));
      min-height: 3.25rem;
      padding: 0.42rem;
    }

    .whatsapp-float__label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .whatsapp-float,
    .whatsapp-float::before {
      transition-duration: 0.001ms;
    }
  }
</style>

<script>
  const whatsappButton = document.querySelector("[data-whatsapp-float]");
  const cookiePanel = document.getElementById("mood-privacy-panel");

  const updateWhatsAppLift = () => {
    if (!(whatsappButton instanceof HTMLElement) || !(cookiePanel instanceof HTMLElement)) return;

    const isCookieVisible = !cookiePanel.hidden && getComputedStyle(cookiePanel).display !== "none";
    const lift = isCookieVisible ? Math.ceil(cookiePanel.getBoundingClientRect().height + 12) : 0;
    whatsappButton.style.setProperty("--mood-whatsapp-lift", `${lift}px`);
  };

  if (whatsappButton && cookiePanel) {
    const mutationObserver = new MutationObserver(updateWhatsAppLift);
    mutationObserver.observe(cookiePanel, {
      attributes: true,
      attributeFilter: ["hidden", "class", "style"],
    });

    if ("ResizeObserver" in window) {
      new ResizeObserver(updateWhatsAppLift).observe(cookiePanel);
    }

    window.addEventListener("resize", updateWhatsAppLift, { passive: true });
    requestAnimationFrame(updateWhatsAppLift);
    setTimeout(updateWhatsAppLift, 700);
  }
</script>
