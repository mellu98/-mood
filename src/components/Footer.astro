---
import { navLinks, site } from "../data/site";
---

<!-- CTA Section: Non sai da dove iniziare? -->
<section class="bg-navy text-white relative overflow-hidden grain-overlay">
  <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-magenta/20 blur-[120px]"></div>
  <div class="absolute -bottom-32 -left-32 w-96 h-96 rounded-full bg-magenta/10 blur-[120px]"></div>

  <div class="max-w-[1280px] mx-auto px-8 md:px-12 lg:px-14 xl:px-10 section-padding relative z-10">
    <div class="max-w-3xl mx-auto text-center" data-reveal>
      <p class="text-label text-magenta mb-6">Non sai da dove iniziare?</p>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl mb-6 leading-[1.05]">
        È normale.
      </h2>
      <p class="text-lg md:text-xl text-white/75 leading-relaxed mb-10 max-w-2xl mx-auto">
        Da Mood non devi scegliere il trattamento giusto.
        Prenota una consulenza e costruiremo insieme il percorso più adatto a te.
      </p>
      <a href="/contatti#consulenza" class="btn-primary !bg-magenta !border-magenta hover:!bg-white hover:!text-magenta hover:!border-white">
        Prenota la tua consulenza
      </a>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="bg-navy-950 text-white/70 border-t border-white/10">
  <div class="max-w-[1280px] mx-auto px-8 md:px-12 lg:px-14 xl:px-10 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 lg:gap-16">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="inline-flex items-center gap-2 mb-5">
          <span class="font-display text-2xl text-white">
            Mood<span class="text-magenta">.</span>
          </span>
          <span class="text-[0.6rem] uppercase tracking-[0.25em] text-white/50 font-semibold">
            Beauty Lab
          </span>
        </a>
        <p class="text-white/60 leading-relaxed max-w-md text-sm">
          Centro di estetica avanzata a Pavia. Consulenze personalizzate,
          tecnologie all'avanguardia e percorsi dedicati al viso, al corpo e al benessere.
          Dal {site.since}.
        </p>
      </div>

      <!-- Nav -->
      <div>
        <h3 class="text-label text-white/40 mb-5">Esplora</h3>
        <ul class="grid grid-cols-2 gap-x-6 gap-y-2.5">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/70 hover:text-magenta transition-colors link-underline">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-label text-white/40 mb-5">Contatti</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={site.mapsUrl} target="_blank" rel="noopener" class="text-white/70 hover:text-magenta transition-colors">
              {site.address.street}<br />
              {site.address.cap} {site.address.city}
            </a>
          </li>
          <li>
            <a href={site.phoneHref} class="text-white/70 hover:text-magenta transition-colors">
              {site.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${site.email}`} class="text-white/70 hover:text-magenta transition-colors break-all">
              {site.email}
            </a>
          </li>
        </ul>
        {
          site.social.instagram && (
            <a
              href={site.social.instagram}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 mt-5 text-sm text-white/70 hover:text-magenta transition-colors"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="2" width="20" height="20" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" />
              </svg>
              Instagram
            </a>
          )
        }
      </div>
    </div>

    <div class="mt-14 pt-8 border-t border-white/10 flex flex-col lg:flex-row items-center justify-between gap-5 text-center lg:text-left">
      <p class="text-xs text-white/40">
        © {new Date().getFullYear()} {site.name}. Tutti i diritti riservati.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-xs">
        <a href="/privacy-policy" class="text-white/45 hover:text-magenta transition-colors">
          Privacy Policy
        </a>
        <a href="/cookie-policy" class="text-white/45 hover:text-magenta transition-colors">
          Cookie Policy
        </a>
        <span class="text-white/35">
          Pavia · {site.address.street}
        </span>
      </div>
    </div>
  </div>
</footer>
