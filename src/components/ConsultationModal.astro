---
import { site } from "../data/site";

const interestOptions = [
  { value: "viso", label: "Viso" },
  { value: "corpo", label: "Corpo" },
  { value: "laser", label: "Laser" },
  { value: "beauty", label: "Beauty" },
  { value: "shop", label: "Shop prodotti" },
  { value: "consulenza", label: "Consulenza generale" },
];
---

<dialog
  id="consultation-modal"
  class="consultation-modal fixed inset-0 z-[80] m-auto w-[min(calc(100vw-1.5rem),980px)] max-h-[calc(100svh-1.5rem)] overflow-y-auto bg-transparent p-0 text-navy"
  aria-labelledby="consultation-modal-title"
  aria-describedby="consultation-modal-description"
>
  <div class="consultation-modal__panel overflow-hidden rounded-2xl bg-white">
    <div class="grid lg:grid-cols-[0.9fr_1.1fr]">
      <aside class="relative overflow-hidden bg-navy p-6 sm:p-8 text-white">
        <div class="absolute -left-24 -top-24 h-56 w-56 rounded-full bg-magenta/35 blur-3xl" aria-hidden="true"></div>
        <div class="absolute -bottom-20 right-0 h-44 w-44 rounded-full bg-rose/25 blur-3xl" aria-hidden="true"></div>

        <div class="relative z-10 flex min-h-full flex-col justify-between gap-10">
          <div>
            <img
              src="/materiale/mood-beauty-lab-logo-definitivo.png"
              alt="Mood Beauty Lab"
              class="mb-8 h-12 w-auto drop-shadow-[0_0_18px_rgba(225,1,152,0.24)]"
              loading="lazy"
              decoding="async"
            />
            <p class="mb-4 text-sm font-semibold text-magenta">Consulenza Mood</p>
            <h2 id="consultation-modal-title" class="font-display text-3xl sm:text-4xl leading-tight text-white">
              Ti aiutiamo a capire<br />
              <span class="italic text-magenta">da dove partire.</span>
            </h2>
            <p id="consultation-modal-description" class="mt-5 text-sm sm:text-base leading-relaxed text-white/74">
              Compila pochi dati: prepariamo un messaggio WhatsApp già ordinato.
              Lo invii tu quando vuoi, senza perdere il punto in cui eri nel sito.
            </p>
          </div>

          <div class="space-y-3 text-sm text-white/72">
            <div class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-magenta"></span>
              <p>Nessun listino impersonale: il percorso parte dalla consulenza.</p>
            </div>
            <div class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-magenta"></span>
              <p>Puoi anche chiamare subito il centro se preferisci parlare.</p>
            </div>
            <a href={site.phoneHref} class="mt-5 inline-flex text-sm font-semibold text-white underline underline-offset-4 hover:text-magenta">
              {site.phone}
            </a>
          </div>
        </div>
      </aside>

      <div class="relative max-h-[calc(100svh-1.5rem)] overflow-y-auto p-6 sm:p-8">
        <button
          type="button"
          class="absolute right-4 top-4 grid h-10 w-10 place-items-center rounded-full bg-navy/5 text-navy transition-colors hover:bg-navy hover:text-white"
          data-consultation-close
          aria-label="Chiudi popup consulenza"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M6 6l12 12M18 6L6 18" />
          </svg>
        </button>

        <div class="mb-7 pr-10">
          <p class="mb-3 text-sm font-semibold text-magenta">Prenota senza scorrere</p>
          <h3 class="font-display text-2xl sm:text-3xl text-navy leading-tight">
            Raccontaci cosa ti serve.
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-navy/65">
            Ti apriremo WhatsApp con il messaggio già pronto. Dovrai solo premere invio nella chat.
          </p>
        </div>

        <form id="consultation-modal-form" class="space-y-4">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="cm-name" class="mb-2 block text-sm font-semibold text-navy/72">Nome e cognome</label>
              <input
                id="cm-name"
                name="name"
                type="text"
                required
                placeholder="Il tuo nome"
                autocomplete="name"
                class="w-full rounded-xl border border-navy/10 bg-navy-50/70 px-4 py-3 text-navy placeholder:text-navy/55 transition-all focus:border-magenta/60 focus:outline-none focus:ring-2 focus:ring-magenta/20"
              />
            </div>
            <div>
              <label for="cm-phone" class="mb-2 block text-sm font-semibold text-navy/72">Telefono</label>
              <input
                id="cm-phone"
                name="phone"
                type="tel"
                required
                placeholder="Il tuo numero"
                autocomplete="tel"
                class="w-full rounded-xl border border-navy/10 bg-navy-50/70 px-4 py-3 text-navy placeholder:text-navy/55 transition-all focus:border-magenta/60 focus:outline-none focus:ring-2 focus:ring-magenta/20"
              />
            </div>
          </div>

          <div>
            <label for="cm-interest" class="mb-2 block text-sm font-semibold text-navy/72">Area di interesse</label>
            <select
              id="cm-interest"
              name="interest"
              class="w-full rounded-xl border border-navy/10 bg-navy-50/70 px-4 py-3 text-navy transition-all focus:border-magenta/60 focus:outline-none focus:ring-2 focus:ring-magenta/20"
            >
              {interestOptions.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </div>

          <div>
            <label for="cm-message" class="mb-2 block text-sm font-semibold text-navy/72">
              Messaggio <span class="font-normal text-navy/60">(opzionale)</span>
            </label>
            <textarea
              id="cm-message"
              name="message"
              rows="4"
              placeholder="Es. Vorrei capire quale trattamento fa per me..."
              class="w-full resize-none rounded-xl border border-navy/10 bg-navy-50/70 px-4 py-3 text-navy placeholder:text-navy/55 transition-all focus:border-magenta/60 focus:outline-none focus:ring-2 focus:ring-magenta/20"
            ></textarea>
          </div>

          <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:items-center">
            <button type="submit" class="btn-primary !bg-magenta !border-magenta hover:!bg-navy hover:!border-navy">
              Prepara richiesta
            </button>
            <a href="/contatti#consulenza" class="text-sm font-semibold text-navy/62 underline underline-offset-4 hover:text-magenta" data-consultation-form-link>
              Vai al form completo
            </a>
          </div>

          <p class="text-xs leading-relaxed text-navy/65">
            I dati inseriti vengono usati per preparare il messaggio WhatsApp. L'invio avviene solo se confermi dentro WhatsApp.
            Leggi la <a href="/privacy-policy" class="font-semibold text-magenta underline underline-offset-4">Privacy Policy</a>.
          </p>
        </form>

        <div id="consultation-modal-success" class="hidden rounded-2xl bg-blush px-5 py-6 text-center" aria-live="polite">
          <p class="font-display text-2xl text-navy">Messaggio preparato.</p>
          <p class="mt-2 text-sm leading-relaxed text-navy/65">
            Se WhatsApp non si è aperto, puoi chiamarci al
            <a href={site.phoneHref} class="font-semibold text-magenta">{site.phone}</a>.
          </p>
        </div>
      </div>
    </div>
  </div>
</dialog>

<style>
  .consultation-modal {
    border: 0;
  }

  .consultation-modal::backdrop {
    background: rgba(3, 8, 32, 0.68);
    backdrop-filter: blur(10px);
  }

  .consultation-modal__panel {
    transform: translateY(14px) scale(0.985);
    opacity: 0;
    transition:
      opacity 0.34s var(--ease-mood),
      transform 0.34s var(--ease-mood);
  }

  .consultation-modal[open] .consultation-modal__panel {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .consultation-modal__panel {
      transition-duration: 0.001ms;
      transform: none;
    }
  }
</style>

<script define:vars={{ whatsappHref: site.whatsappHref }}>
  const consultationModal = document.getElementById("consultation-modal");
  const consultationForm = document.getElementById("consultation-modal-form");
  const consultationSuccess = document.getElementById("consultation-modal-success");
  const interestSelect = document.getElementById("cm-interest");
  const messageField = document.getElementById("cm-message");
  const formLink = document.querySelector("[data-consultation-form-link]");
  let lastConsultationTrigger = null;

  const interestFromContext = (trigger) => {
    const text = `${trigger?.textContent || ""} ${window.location.pathname}`.toLowerCase();
    if (text.includes("viso")) return "viso";
    if (text.includes("corpo")) return "corpo";
    if (text.includes("laser")) return "laser";
    if (text.includes("beauty") || text.includes("ciglia") || text.includes("make")) return "beauty";
    if (text.includes("shop") || text.includes("prodott")) return "shop";
    return "consulenza";
  };

  const resetConsultationModal = () => {
    consultationForm?.classList.remove("hidden");
    consultationSuccess?.classList.add("hidden");
  };

  const openConsultationModal = (trigger) => {
    if (!(consultationModal instanceof HTMLDialogElement) || typeof consultationModal.showModal !== "function") return false;

    lastConsultationTrigger = trigger instanceof HTMLElement ? trigger : null;
    resetConsultationModal();

    if (interestSelect instanceof HTMLSelectElement) {
      interestSelect.value = interestFromContext(lastConsultationTrigger);
    }

    if (messageField instanceof HTMLTextAreaElement && !messageField.value && lastConsultationTrigger) {
      const label = lastConsultationTrigger.textContent?.trim().replace(/\s+/g, " ");
      if (label) messageField.placeholder = `Arrivo da: "${label}". Vorrei una consulenza...`;
    }

    consultationModal.showModal();
    window.setTimeout(() => document.getElementById("cm-name")?.focus(), 80);
    return true;
  };

  const closeConsultationModal = () => {
    if (consultationModal instanceof HTMLDialogElement && consultationModal.open) {
      consultationModal.close();
      lastConsultationTrigger?.focus?.();
    }
  };

  document.querySelectorAll("a[href*='#consulenza']").forEach((trigger) => {
    if (!(trigger instanceof HTMLAnchorElement)) return;
    if (trigger.closest("#consultation-modal")) return;
    let url;
    try {
      url = new URL(trigger.getAttribute("href") || "", window.location.href);
    } catch {
      return;
    }

    const pointsToConsultationForm = url.pathname.replace(/\/$/, "") === "/contatti" && url.hash === "#consulenza";
    if (!pointsToConsultationForm) return;

    trigger.setAttribute("data-opens-consultation-modal", "true");
    trigger.addEventListener("click", (event) => {
      if (event.defaultPrevented || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
      if (openConsultationModal(trigger)) event.preventDefault();
    });
  });

  document.querySelectorAll("[data-consultation-close]").forEach((button) => {
    button.addEventListener("click", closeConsultationModal);
  });

  consultationModal?.addEventListener("click", (event) => {
    if (event.target === consultationModal) closeConsultationModal();
  });

  formLink?.addEventListener("click", () => {
    closeConsultationModal();
  });

  if (consultationForm instanceof HTMLFormElement) {
    consultationForm.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(consultationForm);
      const name = data.get("name");
      const phone = data.get("phone");
      const interest = data.get("interest");
      const message = data.get("message");

      const body = [
        "Ciao Mood Beauty Lab, vorrei prenotare una consulenza.",
        "",
        `Nome: ${name}`,
        `Telefono: ${phone}`,
        `Interesse: ${interest || "Consulenza generale"}`,
        "",
        `Messaggio: ${message || "-"}`,
      ].join("\n");

      const whatsappUrl = `${whatsappHref}?text=${encodeURIComponent(body)}`;
      const opened = window.open(whatsappUrl, "_blank", "noopener,noreferrer");
      if (!opened) window.location.href = whatsappUrl;

      consultationForm.classList.add("hidden");
      consultationSuccess?.classList.remove("hidden");
    });
  }
</script>
