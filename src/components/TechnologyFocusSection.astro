---
import SectionLabel from "./SectionLabel.astro";

interface Props {
  title: string;
  titleAccent: string;
  subtitle: string;
  technologies: string[];
  background?: "warm-white" | "navy-50";
}

const { title, titleAccent, subtitle, technologies, background = "navy-50" } = Astro.props;
const isSoftBlue = background === "navy-50";
---

<section class:list={["section-padding", isSoftBlue ? "bg-navy-50" : "bg-warm-white"]}>
  <div class="max-w-[1280px] mx-auto px-8 md:px-12 lg:px-14 xl:px-10">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-5" data-reveal>
        <SectionLabel text="Tecnologie" />
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-navy leading-[1.05] mb-6">
          {title}<br />
          <span class="italic text-magenta">{titleAccent}</span>
        </h2>
        <p class="text-lg text-navy/65 leading-relaxed">
          {subtitle}
        </p>
      </div>

      <div class="lg:col-span-7" data-reveal data-reveal-delay="2">
        <ul class="grid sm:grid-cols-2 gap-3 lg:gap-4" aria-label={title}>
          {technologies.map((technology, i) => (
            <li
              class="group flex items-center gap-4 rounded-2xl border border-navy/10 bg-white px-5 py-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-magenta/35"
              data-reveal
              data-reveal-delay={String((i % 3) + 1)}
            >
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-blush text-magenta transition-colors duration-300 group-hover:bg-magenta group-hover:text-white">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                  <path d="M12 3l2.4 5.2L20 10l-5.6 1.8L12 21l-2.4-9.2L4 10l5.6-1.8L12 3z" />
                </svg>
              </span>
              <span class="font-display text-lg text-navy leading-tight">{technology}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
