---
import SectionLabel from "./SectionLabel.astro";

interface Props {
  label: string;
  title: string;
  titleAccent?: string;
  subtitle?: string;
  dark?: boolean;
  cta?: string;
  ctaHref?: string;
}
const {
  label,
  title,
  titleAccent,
  subtitle,
  dark = false,
  cta,
  ctaHref = "/contatti#consulenza",
} = Astro.props;
---

<section
  class:list={[
    "relative pt-36 pb-16 lg:pt-44 lg:pb-24 overflow-hidden",
    dark ? "bg-navy text-white" : "bg-blush",
  ]}
>
  {
    dark && (
      <>
        <div class="absolute -top-20 right-0 w-[500px] h-[500px] rounded-full bg-magenta/15 blur-[140px]"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 rounded-full bg-magenta/10 blur-[120px]"></div>
      </>
    )
  }
  <div class="max-w-[1280px] mx-auto px-8 md:px-12 lg:px-14 xl:px-10 relative z-10">
    <div class="max-w-5xl">
      <div data-reveal>
        <SectionLabel text={label} light={dark} />
      </div>
      <h1
        class:list={[
          "font-display text-[clamp(3rem,7vw,5.75rem)] leading-[1.03] tracking-tight mb-7 text-balance",
          dark ? "text-white" : "text-navy",
        ]}
        data-reveal
      >
        {title}{titleAccent && <> <span class="text-magenta block lg:inline">{titleAccent}</span></>}
      </h1>
      {
        subtitle && (
          <p
            class:list={[
              "text-lg md:text-xl leading-[1.75] max-w-[68ch] text-pretty",
              dark ? "text-white/72" : "text-navy/65",
            ]}
            data-reveal
          >
            {subtitle}
          </p>
        )
      }
      {
        cta && (
          <div class="mt-8" data-reveal>
            <a href={ctaHref} class="btn-primary">
              {cta}
            </a>
          </div>
        )
      }
    </div>
  </div>
</section>
