---
interface Props {
  name: string;
  description: string;
  tag?: string;
  featured?: boolean;
}
const { name, description, tag, featured = false } = Astro.props;
---

<div
  class:list={[
    "group relative p-7 lg:p-8 rounded-2xl border transition-all duration-500 hover:-translate-y-1",
    featured
      ? "bg-navy text-white border-navy hover:shadow-2xl hover:shadow-navy/20"
      : "bg-white border-navy-100 hover:border-magenta/30 hover:shadow-xl hover:shadow-navy/5",
  ]}
  data-reveal
>
  {
    tag && (
      <span
        class:list={[
          "text-[0.6rem] uppercase tracking-[0.18em] font-semibold px-3 py-1 rounded-full mb-4 inline-block",
          featured ? "bg-magenta/20 text-magenta-200" : "bg-blush text-magenta",
        ]}
      >
        {tag}
      </span>
    )
  }
  <h3
    class:list={[
      "font-display text-xl lg:text-2xl mb-3 leading-tight break-words hyphens-auto",
      featured ? "text-white" : "text-navy",
    ]}
  >
    {name}
  </h3>
  <p
    class:list={[
      "text-sm leading-relaxed break-words",
      featured ? "text-white/70" : "text-navy/60",
    ]}
  >
    {description}
  </p>
</div>
