---
---

<div
  id="mood-privacy-panel"
  class="fixed inset-x-0 bottom-0 z-40 px-4 pb-4 sm:px-6 sm:pb-6 opacity-0 translate-y-5 transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]"
  hidden
>
  <section
    role="dialog"
    aria-modal="false"
    aria-labelledby="cookie-title"
    aria-describedby="cookie-description"
    class="max-w-[1040px] mx-auto overflow-hidden rounded-3xl bg-navy text-white [box-shadow:0_14px_48px_rgba(5,15,56,0.36)]"
  >
    <div class="h-1 bg-gradient-to-r from-magenta via-rose to-blush" aria-hidden="true"></div>

    <div class="p-5 sm:p-6 lg:p-7">
      <div class="grid gap-5 lg:grid-cols-[1fr_auto] lg:items-end">
        <div class="max-w-2xl">
          <div class="flex items-center gap-4 mb-3">
            <span class="inline-flex items-center">
              <img
                src="/materiale/mood-beauty-lab-logo-definitivo.png"
                alt="Mood Beauty Lab"
                class="h-12 sm:h-14 w-auto drop-shadow-[0_0_18px_rgba(225,1,152,0.26)]"
                loading="eager"
                decoding="async"
              />
            </span>
            <p class="text-[0.68rem] uppercase tracking-[0.24em] text-magenta font-semibold">
              Privacy Mood
            </p>
          </div>

          <h2 id="cookie-title" class="font-display text-2xl sm:text-3xl leading-tight text-white">
            Cookie, ma con grazia.
          </h2>
          <p id="cookie-description" class="mt-3 text-sm sm:text-base leading-relaxed text-white/72">
            Usiamo solo tecnologie essenziali per far funzionare il sito. I servizi esterni,
            come Google Maps, si attivano solo se li autorizzi o li richiedi.
          </p>
          <div class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-xs text-white/55">
            <a href="/privacy-policy" class="hover:text-magenta underline underline-offset-4">Privacy Policy</a>
            <a href="/cookie-policy" class="hover:text-magenta underline underline-offset-4">Cookie Policy</a>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row lg:flex-col gap-3 lg:min-w-[220px]">
          <button
            type="button"
            id="cookie-accept-all"
            class="btn-primary !bg-magenta !border-magenta hover:!bg-white hover:!text-magenta hover:!border-white justify-center"
          >
            Accetta tutto
          </button>
          <button
            type="button"
            id="cookie-essential"
            class="rounded-full px-6 py-3 text-xs font-bold uppercase tracking-[0.18em] bg-white text-navy hover:bg-blush transition-colors"
          >
            Solo essenziali
          </button>
          <button
            type="button"
            id="cookie-manage"
            aria-expanded="false"
            aria-controls="cookie-preferences"
            class="rounded-full px-6 py-3 text-xs font-bold uppercase tracking-[0.18em] text-white/78 hover:text-white hover:bg-white/10 transition-colors"
          >
            Gestisci
          </button>
        </div>
      </div>

      <div id="cookie-preferences" class="mt-6 pt-6 border-t border-white/10" hidden>
        <div class="grid gap-4 md:grid-cols-2">
          <div class="rounded-2xl bg-white/[0.06] p-4">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="text-sm font-semibold text-white">Essenziali</h3>
                <p class="mt-2 text-xs leading-relaxed text-white/58">
                  Necessari per sicurezza, navigazione e salvataggio della tua scelta privacy.
                </p>
              </div>
              <span class="rounded-full bg-white/12 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-white/70">
                Sempre
              </span>
            </div>
          </div>

          <label for="cookie-external" class="rounded-2xl bg-white/[0.06] p-4 cursor-pointer hover:bg-white/[0.09] transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="text-sm font-semibold text-white">Servizi esterni</h3>
                <p class="mt-2 text-xs leading-relaxed text-white/58">
                  Autorizza contenuti come Google Maps quando sono utili alla navigazione.
                </p>
              </div>
              <input id="cookie-external" type="checkbox" class="peer sr-only" />
              <span
                aria-hidden="true"
                class="relative mt-0.5 h-7 w-12 shrink-0 rounded-full bg-white/18 transition-colors peer-checked:bg-magenta peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-white after:absolute after:left-1 after:top-1 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-transform peer-checked:after:translate-x-5"
              ></span>
            </div>
          </label>
        </div>

        <div class="mt-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <p class="text-xs leading-relaxed text-white/45">
            Puoi cambiare idea in qualsiasi momento dal link “Preferenze cookie” nel footer.
          </p>
          <button
            type="button"
            id="cookie-save"
            class="rounded-full px-6 py-3 text-xs font-bold uppercase tracking-[0.18em] bg-white text-navy hover:bg-blush transition-colors"
          >
            Salva preferenze
          </button>
        </div>
      </div>
    </div>
  </section>
</div>

<script>
  const CONSENT_KEY = "mood_cookie_consent";
  const CONSENT_VERSION = 1;

  type MoodConsent = {
    version: number;
    essential: true;
    externalServices: boolean;
    updatedAt: string;
  };

  const banner = document.getElementById("mood-privacy-panel");
  const preferences = document.getElementById("cookie-preferences");
  const manageButton = document.getElementById("cookie-manage");
  const acceptAllButton = document.getElementById("cookie-accept-all");
  const essentialButton = document.getElementById("cookie-essential");
  const saveButton = document.getElementById("cookie-save");
  const externalCheckbox = document.getElementById("cookie-external") as HTMLInputElement | null;

  const readConsent = (): MoodConsent | null => {
    try {
      const raw = window.localStorage.getItem(CONSENT_KEY);
      if (!raw) return null;
      const parsed = JSON.parse(raw) as Partial<MoodConsent>;
      if (parsed.version !== CONSENT_VERSION || parsed.essential !== true) return null;
      return {
        version: CONSENT_VERSION,
        essential: true,
        externalServices: parsed.externalServices === true,
        updatedAt: String(parsed.updatedAt || ""),
      };
    } catch {
      return null;
    }
  };

  const publishConsent = (consent: MoodConsent) => {
    (window as any).MoodCookieConsent = consent;
    window.dispatchEvent(new CustomEvent("mood:privacy-consent", { detail: consent }));
  };

  const writeConsent = (externalServices: boolean) => {
    const consent: MoodConsent = {
      version: CONSENT_VERSION,
      essential: true,
      externalServices,
      updatedAt: new Date().toISOString(),
    };

    try {
      window.localStorage.setItem(CONSENT_KEY, JSON.stringify(consent));
    } catch {
      // Se lo storage è bloccato, usiamo comunque il consenso per la sessione corrente.
    }

    publishConsent(consent);
    hideBanner();
  };

  const setPreferencesOpen = (open: boolean) => {
    if (!preferences || !manageButton) return;
    preferences.hidden = !open;
    manageButton.setAttribute("aria-expanded", String(open));
    manageButton.textContent = open ? "Chiudi" : "Gestisci";
  };

  const showBanner = (options: { openPreferences?: boolean; focusExternal?: boolean } = {}) => {
    if (!banner) return;
    const current = readConsent();
    if (externalCheckbox) externalCheckbox.checked = current?.externalServices === true;

    banner.hidden = false;
    requestAnimationFrame(() => {
      banner.classList.remove("opacity-0", "translate-y-5");
      banner.classList.add("opacity-100", "translate-y-0");
    });

    if (options.openPreferences) {
      setPreferencesOpen(true);
      if (options.focusExternal) {
        window.setTimeout(() => externalCheckbox?.focus(), 120);
      }
    }
  };

  const hideBanner = () => {
    if (!banner) return;
    banner.classList.add("opacity-0", "translate-y-5");
    banner.classList.remove("opacity-100", "translate-y-0");
    window.setTimeout(() => {
      banner.hidden = true;
      setPreferencesOpen(false);
    }, 320);
  };

  acceptAllButton?.addEventListener("click", () => writeConsent(true));
  essentialButton?.addEventListener("click", () => writeConsent(false));
  saveButton?.addEventListener("click", () => writeConsent(externalCheckbox?.checked === true));
  manageButton?.addEventListener("click", () => {
    const isOpen = preferences?.hidden === false;
    setPreferencesOpen(!isOpen);
  });

  document.querySelectorAll("[data-open-cookie-preferences]").forEach((button) => {
    button.addEventListener("click", () => showBanner({ openPreferences: true }));
  });

  window.addEventListener("mood:open-cookie-preferences", ((event: CustomEvent) => {
    showBanner({
      openPreferences: true,
      focusExternal: event.detail?.focusExternal === true,
    });
  }) as EventListener);

  (window as any).MoodCookiePreferences = {
    getConsent: readConsent,
    open: showBanner,
  };

  const forcePreview = new URLSearchParams(window.location.search).has("mood-cookie-preview");
  if (forcePreview) {
    try {
      window.localStorage.removeItem(CONSENT_KEY);
    } catch {
      // Se lo storage è bloccato, mostriamo comunque il banner in preview.
    }
  }

  const existingConsent = readConsent();
  if (existingConsent && !forcePreview) {
    publishConsent(existingConsent);
  } else {
    window.setTimeout(() => showBanner(), 700);
  }
</script>
