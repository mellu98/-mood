---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";
import ConsultationModal from "../components/ConsultationModal.astro";
import MagneticCursor from "../components/MagneticCursor.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import { site } from "../data/site";
import { businessId, seoPages } from "../data/seo";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
  structuredData?: Record<string, any> | Record<string, any>[];
  noHeaderPadding?: boolean;
  darkHero?: boolean;
}

const {
  title = seoPages.home.title,
  description = seoPages.home.description,
  image = "/materiale/brand.png",
  ogType = "website",
  noindex = false,
  structuredData = [],
  noHeaderPadding = false,
  darkHero = false,
} = Astro.props;

const baseUrl = Astro.site ?? new URL("https://moodbeautylab.it");
const normalizedPath = Astro.url.pathname === "/" ? "/" : `${Astro.url.pathname.replace(/\/$/, "")}/`;
const canonical = new URL(normalizedPath, baseUrl);
const ogImage = new URL(image, baseUrl);
const canonicalUrl = canonical.toString();
const ogImageUrl = ogImage.toString();
const brandLogoUrl = new URL("/materiale/mood-beauty-lab-logo-definitivo.png", baseUrl).toString();
const businessUrl = baseUrl.toString().replace(/\/$/, "");
const websiteId = new URL("/#website", baseUrl).toString();
const webpageId = new URL(`${normalizedPath}#webpage`, baseUrl).toString();
const breadcrumbId = new URL(`${normalizedPath}#breadcrumb`, baseUrl).toString();
const pathSegments = normalizedPath.split("/").filter(Boolean);
const breadcrumbLabels: Record<string, string> = {
  "chi-siamo": "Chi siamo",
  viso: "Trattamenti viso",
  corpo: "Trattamenti corpo",
  laser: "Epilazione laser",
  beauty: "Beauty",
  shop: "Shop",
  blog: "Blog",
  contatti: "Contatti",
  "privacy-policy": "Privacy Policy",
  "cookie-policy": "Cookie Policy",
};
const breadcrumbItems = [
  {
    "@type": "ListItem",
    position: 1,
    name: "Home",
    item: businessUrl,
  },
  ...pathSegments.map((segment, index) => ({
    "@type": "ListItem",
    position: index + 2,
    name: breadcrumbLabels[segment] ?? segment.replace(/-/g, " "),
    item: new URL(`/${pathSegments.slice(0, index + 1).join("/")}/`, baseUrl).toString(),
  })),
];
const pageStructuredData = Array.isArray(structuredData) ? structuredData : [structuredData];
const businessJsonLd = {
  "@context": "https://schema.org",
  "@type": "BeautySalon",
  "@id": businessId,
  name: site.name,
  alternateName: "Mood",
  slogan: site.tagline,
  description,
  url: businessUrl,
  telephone: site.phoneE164,
  email: site.email,
  image: ogImageUrl,
  logo: brandLogoUrl,
  hasMap: site.mapsUrl,
  priceRange: "Su consulenza",
  foundingDate: String(site.since),
  address: {
    "@type": "PostalAddress",
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.region,
    postalCode: site.address.cap,
    addressCountry: "IT",
  },
  areaServed: {
    "@type": "City",
    name: site.address.city,
  },
  contactPoint: {
    "@type": "ContactPoint",
    telephone: site.phoneE164,
    contactType: "Prenotazioni e consulenze",
    areaServed: "IT",
    availableLanguage: ["it"],
  },
  knowsAbout: [
    "Trattamenti viso",
    "Trattamenti corpo",
    "Epilazione laser",
    "Laminazione ciglia",
    "Trucco permanente",
    "Skincare professionale",
    "Solari professionali",
    "Profumeria artistica",
  ],
  makesOffer: [
    "Trattamenti viso personalizzati",
    "Trattamenti corpo",
    "Epilazione laser diodo",
    "Laminazione ciglia e sopracciglia",
    "Trucco permanente",
    "Skincare Mood Cosmetics",
    "Solari That’so",
    "Profumi Bon Parfumeur",
  ],
  sameAs: [site.social.instagram, site.social.facebook, site.social.tiktok].filter(Boolean),
};
const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": websiteId,
  name: site.name,
  url: businessUrl,
  inLanguage: "it-IT",
  publisher: {
    "@id": businessId,
  },
};
const webpageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": webpageId,
  url: canonicalUrl,
  name: title,
  description,
  inLanguage: "it-IT",
  isPartOf: {
    "@id": websiteId,
  },
  about: {
    "@id": businessId,
  },
  primaryImageOfPage: {
    "@type": "ImageObject",
    url: ogImageUrl,
  },
  breadcrumb: {
    "@id": breadcrumbId,
  },
};
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": breadcrumbId,
  itemListElement: breadcrumbItems,
};
const jsonLdItems = [businessJsonLd, websiteJsonLd, webpageJsonLd, breadcrumbJsonLd, ...pageStructuredData].filter(
  Boolean
);
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/materiale/brand.png" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={`${site.name} — centro di estetica avanzata a Pavia`} />
    <meta property="og:locale" content="it_IT" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="theme-color" content="#050f38" />

    {
      jsonLdItems.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)}></script>
      ))
    }

    <link rel="preload" href="/fonts/manrope-latin-variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/fraunces-latin-variable.woff2" as="font" type="font/woff2" crossorigin />

    {/* Progressive enhancement: marca el <html> con .js antes de pintar el body.
        Las reglas de scroll-reveal solo ocultan si html.js está activo.
        Así, si JS no carga o falla, TODO el contenido se ve. */}
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body class={noHeaderPadding ? "" : ""}>
    {/* Scroll progress bar — efecto premium */}
    <div id="scroll-progress" aria-hidden="true"></div>
    {/* Custom cursor con blob follower (solo desktop con hover fino) */}
    <MagneticCursor />
    <Header darkHero={darkHero} />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
    <ConsultationModal />
    <CookieConsent />

    <script>
      // ===== Scroll reveal (text/blocks) =====
      // Defensive: wrapped en rAF + fallback de seguridad para above-the-fold.
      const setupReveals = () => {
        const reveals = document.querySelectorAll("[data-reveal], [data-reveal-lines], [data-reveal-img]");
        if (!("IntersectionObserver" in window) || reveals.length === 0) {
          // Sin IO: mostrar todo
          reveals.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
        );
        reveals.forEach((el) => revealObserver.observe(el));

        // Fallback de seguridad: si tras 1.2s algún elemento que está visible
        // en el viewport inicial NO se animó (observer no disparó por la razón
        // que sea), forzar is-visible. Evita el bug de contenido invisible.
        setTimeout(() => {
          const vh = window.innerHeight;
          reveals.forEach((el) => {
            if (el.classList.contains("is-visible")) return;
            const r = el.getBoundingClientRect();
            if (r.top < vh && r.bottom > 0) {
              el.classList.add("is-visible");
            }
          });
        }, 1200);
      };
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupReveals);
      } else {
        requestAnimationFrame(setupReveals);
      }

      // ===== Count-up stats =====
      const counters = document.querySelectorAll("[data-count]");
      const countObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target;
            const target = parseFloat(el.dataset.count || "0");
            const dur = 1600;
            const start = performance.now();
            const tick = (now) => {
              const p = Math.min((now - start) / dur, 1);
              const eased = 1 - Math.pow(1 - p, 3);
              const val = target * eased;
              el.textContent = Number.isInteger(target) ? Math.round(val).toString() : val.toFixed(1);
              if (p < 1) requestAnimationFrame(tick);
              else el.textContent = target.toString();
            };
            requestAnimationFrame(tick);
            countObserver.unobserve(el);
          });
        },
        { threshold: 0.5 }
      );
      counters.forEach((el) => countObserver.observe(el));

      // ===== Magnetic buttons / links (pointer devices only) =====
      const canHover = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
      if (canHover) {
        document.querySelectorAll<HTMLElement>(".magnetic").forEach((el) => {
          const strength = parseFloat(el.dataset.magnetic || "0.35");
          el.addEventListener("mousemove", (e) => {
            const r = el.getBoundingClientRect();
            const x = e.clientX - (r.left + r.width / 2);
            const y = e.clientY - (r.top + r.height / 2);
            el.style.transform = `translate(${x * strength}px, ${y * strength}px)`;
          });
          el.addEventListener("mouseleave", () => {
            el.style.transform = "";
          });
        });
      }

      // ===== Subtle parallax for [data-parallax] elements =====
      const parallaxes = document.querySelectorAll<HTMLElement>("[data-parallax]");
      if (canHover && parallaxes.length && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const onScroll = () => {
          parallaxes.forEach((el) => {
            const r = el.getBoundingClientRect();
            const speed = parseFloat(el.dataset.parallax || "0.1");
            const offset = (r.top + r.height / 2 - window.innerHeight / 2) * speed;
            el.style.transform = `translate3d(0, ${offset}px, 0)`;
          });
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      }

      // ===== Scroll progress bar =====
      const progressEl = document.getElementById("scroll-progress");
      if (progressEl) {
        let progressRaf = 0;
        const updateProgress = () => {
          progressRaf = 0;
          const docH = document.documentElement.scrollHeight - window.innerHeight;
          const pct = docH > 0 ? window.scrollY / docH : 0;
          progressEl.style.transform = `scaleX(${Math.min(pct, 1)})`;
        };
        window.addEventListener(
          "scroll",
          () => {
            if (!progressRaf) progressRaf = requestAnimationFrame(updateProgress);
          },
          { passive: true }
        );
        window.addEventListener("resize", updateProgress, { passive: true });
        updateProgress();
      }

      // ===== Tilt 3D en hover (solo dispositivos con hover fino) =====
      if (canHover && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const MAX_TILT = 8; // grados máximos
        document.querySelectorAll<HTMLElement>(".tilt-card").forEach((card) => {
          const wrap = card.closest(".tilt-wrap") || card.parentElement;
          if (!wrap) return;
          const onMove = (e: MouseEvent) => {
            const r = card.getBoundingClientRect();
            const px = (e.clientX - r.left) / r.width; // 0..1
            const py = (e.clientY - r.top) / r.height; // 0..1
            const tiltY = (px - 0.5) * 2 * MAX_TILT; // -MAX..MAX
            const tiltX = -(py - 0.5) * 2 * MAX_TILT;
            card.style.transform = `rotateX(${tiltX}deg) rotateY(${tiltY}deg) translateZ(0)`;
          };
          const onLeave = () => {
            card.style.transform = "rotateX(0) rotateY(0)";
          };
          wrap.addEventListener("mousemove", onMove, { passive: true });
          wrap.addEventListener("mouseleave", onLeave);
        });
      }

      // ===== Split-letter reveal (hero H1) =====
      // Recorre cada span/linea de bloque dentro del heading y envuelve cada letra.
      // Más robusto que parsear HTML con regex.
      // EXCEPCIÓN: si un span usa background-clip:text (shimmer-text), NO lo
      // spliteamos — el shimmer exige que background+clip estén en el MISMO
      // elemento, y al meter spans child se rompe (texto transparente sin
      // relleno). En su lugar, le damos una animación de entrada conjunta.
      const splitTargets = document.querySelectorAll<HTMLElement>("[data-split]");
      splitTargets.forEach((el) => {
        el.classList.add("split-letters");
        const blockSpans = Array.from(el.children).filter(
          (c) => c.tagName === "SPAN"
        ) as HTMLElement[];
        const targets = blockSpans.length ? blockSpans : [el];

        let letterIdx = 0;
        let lineIdx = 0;
        targets.forEach((lineEl) => {
          const wrapperClass = lineEl.getAttribute("class") || "";
          const text = lineEl.textContent || "";
          if (!text.trim()) return;

          // ¿Tiene shimmer-text o background-clip:text? → NO splitear
          const style = getComputedStyle(lineEl);
          const hasTextClip =
            wrapperClass.includes("shimmer-text") ||
            style.backgroundClip === "text" ||
            style.webkitBackgroundClip === "text";

          if (hasTextClip) {
            // Animación conjunta: fade-in + translateY con delay progresivo
            lineEl.classList.add("no-split-reveal");
            lineEl.style.setProperty("--line-i", String(lineIdx));
            lineIdx++;
            return;
          }

          // Splitear normal
          const letters = text
            .split("")
            .map((ch) => {
              const safe = ch === " " ? "&nbsp;" : ch;
              const i = letterIdx++;
              return `<span class="split-char" data-letter="${i}" style="--i:${i}">${safe}</span>`;
            })
            .join("");
          lineEl.innerHTML = letters;
          if (wrapperClass) lineEl.setAttribute("class", wrapperClass);
          lineIdx++;
        });
      });
      if (splitTargets.length) {
        requestAnimationFrame(() => {
          setTimeout(() => {
            splitTargets.forEach((el) => el.classList.add("is-revealed"));
          }, 120);
        });
      }
    </script>
  </body>
</html>
